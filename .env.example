# Скопируйте в .env и заполните значения
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5001

# База данных
# DATABASE_URL=sqlite:///meetplan.db
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Email владельца — всегда admin (через запятую для нескольких)
ADMIN_EMAILS=you@example.com

# Часовой пояс новых пользователей по умолчанию
DEFAULT_USER_TIMEZONE=Europe/Moscow

# Flask-Migrate (Pre-Deploy на Render)
# FLASK_APP=run.py
